{
  "name": "customary-testing",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "// ---- public ---- //": "//",
    "test": "wireit",
    "// ---- troubleshoot ---- //": "//",
    "test:in-dist": "wireit",
    "// ---- make ---- //": "//",
    "dist": "wireit",
    "clean": "wireit",
    "// ---- dev ---- //": "//",
    "dev": "wireit",
    "test:in-src": "wireit",
    "compile:watch": "wireit",
    "// ---- command ---- //": "//",
    "dist:library": "wireit",
    "compile": "wireit",
    "// ---- workaround ---- //": "//",
    "fix-mocha-html-reporter": "./package-json-fix-mocha-html-reporter.sh"
  },
  "wireit": {
    "test": {
      "command": "npm run test:in-dist",
      "service": true,
      "dependencies": [
        "dist"
      ]
    },
    "test:in-dist": {
      "command": "npx web-dev-server --watch --root-dir=.dist/development --open=/test.html",
      "service": true
    },
    "dist": {
      "command": "npm run dist:library",
      "dependencies": [
        "build"
      ]
    },
    "dist:library": {
      "command": "npx webpack"
    },
    "build": {
      "command": "npm run compile",
      "dependencies": [
        "clean",
        "dist:participants"
      ]
    },
    "compile": {
      "command": "tsc --build --pretty --verbose"
    },
    "clean": {
      "dependencies": [
        "clean:dist",
        "clean:src"
      ]
    },
    "clean:dist": {
      "command": "rimraf .dist"
    },
    "clean:src": {
      "command": "rimraf --glob src/**/*.{d.ts,js.map,js} --glob tsconfig.tsbuildinfo"
    },
    "dev": {
      "command": "npm run compile:watch",
      "service": true
    },
    "compile:watch": {
      "command": "tsc --build --pretty --verbose --watch",
      "service": true
    },
    "dist:participants": {
      "dependencies": [
        "../customary:dist",
        "../customary-testing-mocha-runner:dist"
      ]
    }
  },
  "dependencies": {
    "chai": "6.2.2",
    "customary": "file:../customary",
    "mocha": "11.7.5",
    "mocha-json-serialize-reporter": "1.7.0"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@web/dev-server": "0.4.6",
    "copy-webpack-plugin": "14.0.0",
    "remove-files-webpack-plugin": "1.5.0",
    "replace-in-file-webpack-plugin": "1.0.6",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2",
    "wireit": "0.14.12"
  },
  "imports": {
    "#customary-testing/*.js": "./src/*.ts",
    "#test-runner-customary/*.js": "./src/test-runner-customary/*.ts",
    "#customary/*.js": "./node_modules/customary/src/*.ts"
  },
  "license": "MIT",
  "author": "Andre de Oliveira"
}
